INPUT INSTRUCTIONS


  TITLE: One-factor 3-class FMM
  DATA:FILE IS mplus1.dat;
  VARIABLE:NAMES ARE M1-M5 tc;
  USEVARIABLES = M1-M5;
  CLASSES = c(3);

  ANALYSIS: TYPE = MIXTURE;
  ALGORITHM = INTEGRATION;
  STARTS 200 20;
  !OPTSEED = 991329;
  LRTSTARTS = 0 0 500 200;
  ESTIMATOR = MLR;

  MODEL: %OVERALL%
      f BY M1-M5;     ! yükler genel (invariant) kalır
      [f@0];          ! referans sınıf için ortalama sabitlenir (varsayılan c#1'dir)
      f@1;            ! referans sınıf varyansı sabitlenir (ölçekleme)

    %c#2%
      [f*];           ! sınıf 2 faktör ortalaması serbest

    %c#3%
      [f*];           ! sınıf 3 faktör ortalaması serbest

  !OUTPUT: SVALUES (1 2) TECH8 TECH11 ;
  OUTPUT: TECH8 TECH11 TECH14;



